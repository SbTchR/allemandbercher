---
import { navigationItems } from '../data/navigation';
import { withBase } from '../lib/paths';

const basePath = import.meta.env.BASE_URL.replace(/\/+$/, '');
const currentPath = Astro.url.pathname.replace(basePath, '') || '/';

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="site-header">
  <a class="brand" href={withBase('/')} aria-label="Retour à l’accueil">
    <span class="brand-mark" aria-hidden="true">AB</span>
    <span>Allemand Bercher</span>
  </a>
  <nav class="main-nav" aria-label="Navigation principale">
    {
      navigationItems.map((item) => (
        <a class:list={{ active: isActive(item.href) }} href={withBase(item.href)}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
