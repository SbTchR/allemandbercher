---
type Link = {
  label?: string;
  url: string;
};

type Props = {
  links?: Link[];
  title?: string;
};

const { links = [], title = 'Ressources en ligne' } = Astro.props;

function linkLabel(link: Link) {
  if (link.label?.trim()) return link.label;

  try {
    const url = new URL(link.url);
    const host = url.hostname.replace(/^www\./, '');
    const path = decodeURIComponent(url.pathname).replace(/\/+$/, '');
    const usefulPath = path
      .split('/')
      .filter(Boolean)
      .slice(0, 2)
      .join('/');

    return usefulPath ? `${host}/${usefulPath}` : host;
  } catch {
    return link.url;
  }
}
---

{
  links.length > 0 && (
    <aside class="link-box" aria-labelledby="external-links-title">
      <h2 id="external-links-title">{title}</h2>
      <ul>
        {links.map((link) => (
          <li>
            <a href={link.url} rel="noreferrer" target="_blank">
              {linkLabel(link)}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
