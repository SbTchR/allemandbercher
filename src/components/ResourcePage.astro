---
import { render } from 'astro:content';
import ExternalLinks from './ExternalLinks.astro';
import ImageGallery from './ImageGallery.astro';
import Layout from './Layout.astro';
import ObjectiveBox from './ObjectiveBox.astro';
import TheoryBox from './TheoryBox.astro';
import type { ResourceEntry } from '../lib/resources';

type Props = {
  entry: ResourceEntry;
};

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <article class="resource-page">
    <header class="resource-header">
      <p class="eyebrow">
        {entry.data.level ? `${entry.data.section} - ${entry.data.level}` : entry.data.section}
      </p>
      <h1>{entry.data.title}</h1>
      {entry.data.description && <p class="lead">{entry.data.description}</p>}
    </header>

    <div class="resource-layout">
      <div class="prose">
        {
          entry.collection === 'theorie' ? (
            <TheoryBox category={entry.data.category}>
              <Content />
            </TheoryBox>
          ) : (
            <Content />
          )
        }
      </div>

      <aside class="resource-aside">
        <ObjectiveBox objectives={entry.data.objectives} />
        <ExternalLinks links={entry.data.externalLinks} />
        {
          entry.data.sourceUrl && (
            <div class="source-box">
              <h2>Source</h2>
              <a href={entry.data.sourceUrl} rel="noreferrer" target="_blank">
                Page Google Sites d’origine
              </a>
            </div>
          )
        }
      </aside>
    </div>

    <ImageGallery images={entry.data.images} />
  </article>
</Layout>
