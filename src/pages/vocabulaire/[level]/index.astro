---
import { getCollection } from 'astro:content';
import Layout from '../../../components/Layout.astro';
import ResourceGrid from '../../../components/ResourceGrid.astro';
import { byOrderThenTitle } from '../../../lib/resources';

export async function getStaticPaths() {
  return ['9h', '10h', '11h'].map((level) => ({ params: { level } }));
}

const level = Astro.params.level?.toUpperCase() as '9H' | '10H' | '11H';
const entries = (await getCollection('vocabulaire', (entry) => entry.data.level === level)).sort(byOrderThenTitle);
---

<Layout title={`Vocabulaire ${level}`} description={`Vocabulaire d’allemand pour le niveau ${level}.`}>
  <section class="hero compact-hero">
    <p class="eyebrow">Vocabulaire</p>
    <h1>{level}</h1>
    <p class="lead">Chapitres de vocabulaire pour réviser les mots et expressions de l’année.</p>
  </section>

  <section class="content-band">
    <ResourceGrid entries={entries} />
  </section>
</Layout>
