---
import { getCollection } from 'astro:content';
import ResourcePage from '../../../components/ResourcePage.astro';

export async function getStaticPaths() {
  const entries = await getCollection('vocabulaire');
  return entries
    .filter((entry) => entry.data.level)
    .map((entry) => ({
      params: {
        level: entry.data.level?.toLowerCase(),
        slug: entry.id.split('/').pop(),
      },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---

<ResourcePage entry={entry} />
