---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import ResourceGrid from '../../components/ResourceGrid.astro';
import { byLevelThenOrder } from '../../lib/resources';
import { withBase } from '../../lib/paths';

const entries = (await getCollection('vocabulaire')).sort(byLevelThenOrder);
const levels = ['9H', '10H', '11H'] as const;
---

<Layout title="Vocabulaire" description="Vocabulaire d’allemand par niveau et par chapitre.">
  <section class="hero compact-hero">
    <p class="eyebrow">Mots et expressions</p>
    <h1>Vocabulaire</h1>
    <p class="lead">Quizlet, Gimkit, Blooket et applications de révision pour les listes de vocabulaire.</p>
  </section>

  <section class="content-band">
    <div class="source-intro prose">
      <p><a href="https://sites.google.com/view/vocallemand/accueil">Nouvelle application "faite-maison"</a></p>
      <p>Application smartphone recommandée : Cabuu</p>
      <h2>Geni@l Klick 9H</h2>
      <p>Kapitel 1 à Kapitel 8</p>
      <h2>Geni@l Klick 10H</h2>
      <p>Kapitel 1 à Kapitel 8</p>
      <h2>Geni@l 11H</h2>
      <p>Kapitel 1 à Kapitel 8</p>
    </div>
  </section>

  {
    levels.map((level) => (
      <section class="content-band" aria-labelledby={`vocabulaire-${level}`}>
        <div class="section-heading">
          <div>
            <p class="eyebrow">Niveau</p>
            <h2 id={`vocabulaire-${level}`}>{level}</h2>
          </div>
          <a class="text-link" href={withBase(`/vocabulaire/${level.toLowerCase()}/`)}>Voir l’index {level}</a>
        </div>
        <ResourceGrid entries={entries.filter((entry) => entry.data.level === level)} />
      </section>
    ))
  }
</Layout>
