---
import Layout from '../components/Layout.astro';
---

<Layout title="Exercices" description="Exercices d’allemand classés par thème et par chapitre.">
  <section class="hero">
    <p class="eyebrow">Entraînement</p>
    <h1>Exercices</h1>
    <p class="lead">
      Les activités seront classées progressivement par niveau, chapitre et objectif de langue.
    </p>
  </section>

  <section class="content-band">
    <h2>Structure prévue</h2>
    <ul class="resource-list">
      <li>
        <strong>Par chapitre</strong>
        <p>Liens vers les exercices liés aux chapitres 9H, 10H et 11H.</p>
      </li>
      <li>
        <strong>Par compétence</strong>
        <p>Grammaire, vocabulaire, compréhension, production et révision.</p>
      </li>
    </ul>
  </section>
</Layout>
