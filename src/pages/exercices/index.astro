---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { byOrderThenTitle, resourceUrl } from '../../lib/resources';
import { withBase } from '../../lib/paths';

const exercices = await getCollection('exercices');
const byLevel = {
  'Geni@l Klick 9H': exercices.filter((entry) => entry.data.level === '9H').sort(byOrderThenTitle),
  'Geni@l 10H': exercices.filter((entry) => entry.data.level === '10H').sort(byOrderThenTitle),
  'Geni@l 11H': exercices.filter((entry) => entry.data.level === '11H').sort(byOrderThenTitle),
};

const sectionId = (label: string) => label.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<Layout title="Exercices" description="Exercices d’allemand classés par niveau et par chapitre.">
  <section class="hero compact-hero">
    <h1>Geni@l</h1>
  </section>

  {
    Object.entries(byLevel).map(([label, entries]) => (
      <section class="content-band" aria-labelledby={`exercices-${sectionId(label)}`}>
        <div class="section-heading">
          <div>
            <h2 id={`exercices-${sectionId(label)}`}>{label}</h2>
          </div>
          <a class="text-link" href={withBase(`/exercices/${entries[0]?.data.level.toLowerCase()}/`)}>
            Voir l’index {entries[0]?.data.level}
          </a>
        </div>
        <ul class="resource-list">
          {entries.map((entry) => (
            <li>
              <a href={resourceUrl(entry)}>{entry.data.title.replace(/^K(\d+)\\s*-\\s*/u, 'Kapitel $1 - ')}</a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Layout>
