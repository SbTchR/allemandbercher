---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import ResourceGrid from '../../components/ResourceGrid.astro';
import { byLevelThenOrder } from '../../lib/resources';
import { withBase } from '../../lib/paths';

const exercices = (await getCollection('exercices')).sort(byLevelThenOrder);
const byLevel = {
  '9H': exercices.filter((entry) => entry.data.level === '9H'),
  '10H': exercices.filter((entry) => entry.data.level === '10H'),
  '11H': exercices.filter((entry) => entry.data.level === '11H'),
};
---

<Layout title="Exercices" description="Exercices d’allemand classés par niveau et par chapitre.">
  <section class="hero compact-hero">
    <p class="eyebrow">Entraînement</p>
    <h1>Exercices</h1>
    <p class="lead">Activités récupérées depuis l’audit du site source, prêtes à être nettoyées et enrichies chapitre par chapitre.</p>
  </section>

  {
    Object.entries(byLevel).map(([level, entries]) => (
      <section class="content-band" aria-labelledby={`exercices-${level}`}>
        <div class="section-heading">
          <div>
            <p class="eyebrow">Niveau</p>
            <h2 id={`exercices-${level}`}>{level}</h2>
          </div>
          <a class="text-link" href={withBase(`/exercices/${level.toLowerCase()}/`)}>Voir l’index {level}</a>
        </div>
        <ResourceGrid entries={entries} />
      </section>
    ))
  }
</Layout>
