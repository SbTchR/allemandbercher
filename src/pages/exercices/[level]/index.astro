---
import { getCollection } from 'astro:content';
import Layout from '../../../components/Layout.astro';
import { byOrderThenTitle, resourceUrl } from '../../../lib/resources';

export async function getStaticPaths() {
  return ['9h', '10h', '11h'].map((level) => ({ params: { level } }));
}

const level = Astro.params.level?.toUpperCase() as '9H' | '10H' | '11H';
const exercices = (await getCollection('exercices', (entry) => entry.data.level === level)).sort(byOrderThenTitle);
---

<Layout title={`Exercices ${level}`} description={`Exercices d’allemand pour le niveau ${level}.`}>
  <section class="hero compact-hero">
    <h1>{level}</h1>
  </section>

  <section class="content-band">
    <ul class="resource-list">
      {exercices.map((entry) => (
        <li>
          <a href={resourceUrl(entry)}>{`Kapitel ${entry.data.order ?? ''}`.trim()}</a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
