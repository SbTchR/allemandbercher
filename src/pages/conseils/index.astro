---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import ResourceGrid from '../../components/ResourceGrid.astro';
import { byOrderThenTitle } from '../../lib/resources';

const conseils = (await getCollection('conseils')).sort(byOrderThenTitle);
---

<Layout title="Conseils" description="Conseils pour améliorer ses compétences communicatives et préparer les tests.">
  <section class="hero compact-hero">
    <p class="eyebrow">Méthodes</p>
    <h1>Conseils</h1>
    <p class="lead">Méthodes et stratégies récupérées depuis le site source, classées par compétence.</p>
  </section>

  <section class="content-band">
    <ResourceGrid entries={conseils} />
  </section>
</Layout>
