---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { byOrderThenTitle } from '../../lib/resources';
import { resourceUrl } from '../../lib/resources';

const conseils = (await getCollection('conseils')).sort(byOrderThenTitle);
---

<Layout title="Conseils" description="Conseils pour améliorer ses compétences communicatives et préparer les tests.">
  <section class="hero compact-hero">
    <h1>Conseils</h1>
    <p class="lead">Pour améliorer ses compétences communicatives et bien se préparer aux tests</p>
  </section>

  <section class="content-band">
    <ul class="resource-list">
      {
        conseils.map((entry) => (
          <li>
            <a href={resourceUrl(entry)}>{entry.data.title}</a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
