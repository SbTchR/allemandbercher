---
import Layout from '../../../components/Layout.astro';
import { chapterLevels } from '../../../data/chapters';

const level = chapterLevels.find((item) => item.level === '11H');
---

<Layout title="Chapitres 11H" description="Ressources d’allemand pour les chapitres de 11H.">
  <section class="hero">
    <p class="eyebrow">Chapitres</p>
    <h1>11H</h1>
    <p class="lead">{level?.description}</p>
  </section>

  <section class="content-band">
    <h2>Pages de chapitre à créer</h2>
    <p>Les chapitres 11H seront ajoutés ici au fur et à mesure de la migration.</p>
  </section>
</Layout>
